{
  "name": "tree-sitter-mql5",
  "version": "0.2.4",
  "description": "Tree-sitter grammar for MQL5",
  "main": "bindings/node",
  "tree-sitter": [
    {
      "scope": "source.mql5",
      "file-types": [
        "mq5",
        "mqh"
      ]
    }
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "build": "tree-sitter build",
    "test": "tree-sitter test"
  },
  "keywords": [
    "tree-sitter",
    "mql5",
    "grammar"
  ],
  "repository": "https: //github.com/cfournel/tree-sitter-mql5",
  "license": "MIT",
  "author": "https: //github.com/cfournel",
  "devDependencies": {
    "tree-sitter-cli": "^0.26.6"
  }
}
